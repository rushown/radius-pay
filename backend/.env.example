# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://radiuspay.app,http://localhost:5173

# ── Database ─────────────────────────────────────────────────────────────────
DB_PATH=./data/radiuspay.db

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Arc RPC (used for on-chain verification, optional) ───────────────────────
ARC_RPC_URL=https://rpc.testnet.arc.network
LINKPAY_CONTRACT=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# ── Security ─────────────────────────────────────────────────────────────────
# Never commit real values — use a secrets manager in production
API_KEY_SECRET=change_me_in_production
